{
  "schema_version": 1,
  "PIPELINE_RULES": [
    {
      "name": "german-symbol-cleanup",
      "label": "German + symbol cleanup",
      "enabled": true,
      "locked": false,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "",
      "type": "regex-list",
      "entries": [
        {
          "pattern": "ß",
          "replacement": "ss",
          "label": "replace-szet-lc",
          "note": "Swiss Standard German drops the eszett entirely — it is always written 'ss'. This rule enforces that for the lowercase form."
        },
        {
          "pattern": "ẞ",
          "replacement": "SS",
          "label": "replace-szet-uc",
          "note": "Uppercase counterpart of replace-szet-lc — the capital eszett 'ẞ' becomes 'SS'."
        },
        {
          "pattern": "[\\\"#$%&'()*+;<=>@\\[\\\\\\]^_`{|}~„]",
          "replacement": "",
          "label": "strip-non-keep-punct",
          "note": "Anything in string.punctuation NOT in ./-:,?! is removed, plus the German low quote „. The remaining ./-:,?! are kept on purpose so the later strip rules' digit-protected logic can run."
        },
        {
          "pattern": "(\\d)\\s*-\\s*(\\d)",
          "replacement": "\\1/\\2",
          "label": "normalize-digit-range",
          "note": "A spoken digit range like '10 - 12' is normalized to '10/12' — slash is the house convention for ranges."
        }
      ]
    },
    {
      "name": "strip-and-lowercase-non-noun",
      "label": "Strip + lowercase next non-noun",
      "enabled": true,
      "locked": false,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "Pass A: paired strip — match a terminator + capitalized word, strip the terminator and lowercase the next word IFF it is in the wordlist. German nouns are always capitalized, so the wordlist holds non-nouns (interrogatives, conjunctions, articles, etc.); matching is case-insensitive.",
      "type": "callback:lowercase-wordlist",
      "pattern": "(?<!\\d)[.?!](\\s*)([A-ZÄÖÜ])(\\w*)",
      "wordlist": [
        "wie",
        "was",
        "wer",
        "wann",
        "wo",
        "warum",
        "wieso",
        "weshalb",
        "welche",
        "welcher",
        "welches",
        "welchem",
        "welchen",
        "und",
        "oder",
        "aber",
        "doch",
        "denn",
        "weil",
        "wenn",
        "dann",
        "dass",
        "obwohl",
        "während",
        "sondern",
        "deshalb",
        "trotzdem",
        "falls",
        "ob",
        "der",
        "die",
        "das",
        "den",
        "dem",
        "des",
        "ein",
        "eine",
        "einer",
        "einem",
        "einen",
        "eines",
        "kein",
        "keine",
        "keiner",
        "keinem",
        "keinen",
        "auch",
        "nur",
        "noch",
        "schon",
        "hier",
        "da",
        "dort",
        "heute",
        "morgen",
        "gestern",
        "jetzt",
        "nicht",
        "sehr",
        "ganz",
        "etwas",
        "viel",
        "wenig",
        "oft",
        "immer",
        "in",
        "auf",
        "an",
        "von",
        "mit",
        "zu",
        "bei",
        "aus",
        "über",
        "unter",
        "vor",
        "nach",
        "für",
        "gegen",
        "ohne",
        "um",
        "durch",
        "ab",
        "seit",
        "ist",
        "sind",
        "war",
        "waren",
        "hat",
        "haben",
        "wird",
        "werden",
        "kann",
        "soll",
        "muss",
        "will",
        "könnte",
        "sollte",
        "müsste",
        "wollte"
      ]
    },
    {
      "name": "strip-whisper-punctuation",
      "label": "Strip Whisper punctuation",
      "enabled": true,
      "locked": false,
      "seeded": true,
      "exposed": false,
      "tags": [
        "whisper-punct"
      ],
      "note": "",
      "type": "regex-list",
      "entries": [
        {
          "pattern": "\\s*\\.+\\s*$",
          "replacement": "",
          "label": "trim-trailing-period"
        },
        {
          "pattern": "(?<!\\d)[.?!]|(?<!\\d),|,(?!\\d)",
          "replacement": "",
          "label": "strip-only-terminators-and-commas",
          "note": "Plain strip — catches lone .?! the paired pass missed, plus soft-pause commas. Digit-protected: '1,000' survives; 'Frau, Müller' loses the comma. Replacement is empty; no side effects."
        }
      ]
    },
    {
      "name": "split-dictation-keywords",
      "label": "Split glued dictation keywords",
      "enabled": true,
      "locked": false,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "",
      "type": "regex-list",
      "entries": [
        {
          "pattern": "\\b([A-ZÄÖÜ][a-zäöüß]{2,})komm?a\\b",
          "replacement": "\\1 Komma",
          "label": "split-merged-komma-off-preceding-noun"
        },
        {
          "pattern": "(?i)\\Bbindestrich|bindestrich\\B",
          "replacement": " Bindestrich ",
          "label": "1-2-split-dictation-words-from-german-compounds",
          "note": "Wörter wie \"Eisenbindestrichinfusion\" auftrennen zu \"Eisen Bindestrich infusion\""
        }
      ]
    },
    {
      "name": "dictation-map",
      "label": "Dictation map",
      "enabled": true,
      "locked": true,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "",
      "type": "callback:map",
      "map": {
        " Binde Strich ": "-",
        " Binde Strich Abstand": "-",
        " Bindestrich ": "-",
        " Bindestrich  ": "-",
        " Bindestrich Abstand": "-",
        " Prozent": "%",
        "Anführungszeichen oben": "“",
        "Anführungszeichen unten": "„",
        "Apostroph": "'",
        "Ausrufezeichen": "!",
        "Ausrufungszeichen": "!",
        "Backslash": "\\",
        "Dach": "^",
        "Dollarzeichen": "$",
        "Doppelpunkt": ":",
        "Et-Zeichen": "&",
        "Eurozeichen": "€",
        "Fragezeichen": "?",
        "Franken": "CHF",
        "Frankenzeichen": "CHF",
        "Gedankenstrich": "–",
        "Gleichheitszeichen": "=",
        "Gradzeichen": "°",
        "Gänsefüsschen": "\"",
        "Gänsefüßchen": "\"",
        "Kaufmannsund": "&",
        "Klammer auf": "(",
        "Klammer auf,": "(",
        "Klammer zu": ")",
        "Klammer zu,": ")",
        "Klammeraffe": "@",
        "Komma": ",",
        "MRE": "MRI",
        "Minus": "-",
        "Minuszeichen": "-",
        "Neuezeile": "\n",
        "Paragraph": "§",
        "Paragraphenzeichen": "§",
        "Pipe": "|",
        "Plus": "+",
        "Pluszeichen": "+",
        "Prozentzeichen": "%",
        "Punkt": ".",
        "Raute": "#",
        "Römisch 1": "I",
        "Römisch 10": "X",
        "Römisch 2": "II",
        "Römisch 3": "III",
        "Römisch 4": "IV",
        "Römisch 5": "V",
        "Römisch 6": "VI",
        "Römisch 7": "VII",
        "Römisch 8": "VIII",
        "Römisch 9": "IX",
        "Schrägstrich": "/",
        "Semikolon": ";",
        "Sternchen": "*",
        "Strichpunkt": ";",
        "Tilde": "~",
        "Trennstrich": "-",
        "Und-Zeichen": "&",
        "Unterstrich": "_",
        "comma": ",",
        "eckige Klammer auf": "[",
        "eckige Klammer zu": "]",
        "geschweifte Klammer auf": "{",
        "geschweifte Klammer zu": "}",
        "größer als": ">",
        "kleiner als": "<",
        "neue Absätze": "\n\n",
        "neue Seile": "\n",
        "neue Säule": "\n",
        "neue Teile": "\n",
        "neue Zeile": "\n",
        "neue Zeilen": "\n",
        "neuer Absatz": "\n\n",
        "neuer Absätze": "\n\n",
        "neuer Apfel": "\n\n",
        "noch Ihr Absatz": "\n\n"
      },
      "map_meta": {}
    },
    {
      "name": "2-2-capitalize-the-letter-after-a-hyphen",
      "label": "[2/2] Capitalize the letter after a hyphen",
      "enabled": true,
      "locked": false,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "",
      "type": "callback:upper",
      "pattern": "(-)([a-zäöüß])"
    },
    {
      "name": "digit-and-whitespace-tidy",
      "label": "Digit + whitespace tidy",
      "enabled": true,
      "locked": true,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "",
      "type": "regex-list",
      "entries": [
        {
          "pattern": "(\\d)\\s*([/,\\-])\\s*(\\d)",
          "replacement": "\\1\\2\\3",
          "label": "tighten-digit-separators"
        },
        {
          "pattern": "(?<=\\d) +(?=\\d[/\\-])",
          "replacement": "",
          "label": "merge-digit-pair-before"
        },
        {
          "pattern": "(?<=[/\\-]\\d) +(?=\\d)",
          "replacement": "",
          "label": "merge-digit-pair-after"
        },
        {
          "pattern": "[ \\t]+([,.:;!?%\\)\\]\\}])",
          "replacement": "\\1",
          "label": "space-before-closing-punct",
          "note": "Drop whitespace before closing punctuation so ' ,' / ' )' tighten up to ',' / ')'."
        },
        {
          "pattern": "([\\(\\[\\{])[ \\t]+",
          "replacement": "\\1",
          "label": "space-after-opening-punct",
          "note": "Drop whitespace after an opening bracket so '( ' tightens to '('."
        },
        {
          "pattern": "  +",
          "replacement": " ",
          "label": "collapse-multi-space",
          "note": "Whisper segments are joined with an empty separator — if both adjacent segments end/start with whitespace the join produces an interior double-space that no other rule cleans (the punctuation-adjacent tidy rules do not match it)."
        }
      ]
    },
    {
      "name": "dedup-punct",
      "label": "Dedup punctuation runs",
      "enabled": true,
      "locked": true,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "Whisper emits its own commas as soft pauses around dictation keywords, so after substitution we get runs like ',.' or ',;'. The user's intended mark wins: prefer any non-comma in the run, and within non-commas prefer the LAST one (the dictation came after the Whisper pause). A pure-comma run collapses to a single comma.",
      "type": "callback:dedup",
      "pattern": "[,.:;!?]{2,}"
    },
    {
      "name": "final-cleanup",
      "label": "Final cleanup",
      "enabled": true,
      "locked": true,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "",
      "type": "regex-list",
      "entries": [
        {
          "pattern": "[ \\t]*,?[ \\t]*(\\n+)[ \\t]*,?[ \\t]*",
          "replacement": "\\1",
          "label": "tidy-newlines",
          "note": "Around a dictation-emitted newline there is often residue: a Whisper-emitted comma ('Müller, \\n'), a trailing space, or punctuation that leaked through ('\\n , Welt'). Collapse the neighborhood — optional whitespace + optional comma — on each side."
        },
        {
          "pattern": "(?:,|\\.)(- |-)",
          "replacement": "",
          "label": "replace-and"
        }
      ]
    },
    {
      "name": "capitalize-after-terminator",
      "label": "Capitalize after sentence terminator",
      "enabled": true,
      "locked": true,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "After dictation inserts '.', '?', '!' or a newline, the following letter starts a new sentence/paragraph. Whisper does not know about our substitution, so it leaves that letter lowercase — fix it here.",
      "type": "callback:upper",
      "pattern": "([.?!]\\s+|\\n+\\s*)([a-zäöüß])"
    },
    {
      "name": "trim-edges",
      "label": "Trim edges (always-last)",
      "enabled": true,
      "locked": true,
      "seeded": true,
      "exposed": false,
      "tags": [],
      "note": "Final, hardcoded terminal step — runs after the loop. lstrip + rstrip strip leading and trailing space/tab/CR but NOT '\\n', so a user-dictated leading or trailing 'neue Zeile' at the edges of the utterance survives.",
      "type": "terminal"
    }
  ]
}